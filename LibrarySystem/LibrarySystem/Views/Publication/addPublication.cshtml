@using LibrarySystem.Shared.PublicationData
@model PublicationDetails
<h1>Add Publication</h1>
<form asp-controller="Publication" asp-action="AddPublication" method="post">
    <div asp-validation-summary="All" class="text-danger"></div>
    <div class="form-group">
        <label asp-for="PublicationName">Publication Name</label>
        <input type="text" asp-for="PublicationName" placeholder="Enter Publication Name" class="form-control" />
        <span asp-validation-for="PublicationName" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="PublicationAddress">Author Name</label>
        <input type="text" asp-for="PublicationAddress" placeholder="Enter Author Name" class="form-control" />
        <span asp-validation-for="PublicationAddress" class="text-danger"></span>
    </div>
    
    <br>
    <div class="form-group">
        <input type="submit" value="Submit" class="btn btn-success" />
    </div>

</form>


@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
