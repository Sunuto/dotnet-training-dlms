@using LibrarySystem.Repository.Models
@model LibraryLocationDetails
<h1>Edit Location</h1>
<form asp-controller="Location" asp-action="EditLocation" method="post">
    <div asp-validation-summary="All" class="text-danger"></div>
    <div class="form-group">
        <label asp-for="Aisle">Aisle</label>
        <input type="text" asp-for="Aisle" placeholder="Enter Aisle" class="form-control" />
        <span asp-validation-for="Aisle" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Shelf">Shelf</label>
        <input type="text" asp-for="Shelf" placeholder="Enter Shelf" class="form-control" />
        <span asp-validation-for="Shelf" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Section">Section</label>
        <input type="text" asp-for="Section" placeholder="Enter Section" class="form-control" />
        <span asp-validation-for="Section" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Floor">Floor</label>
        <input type="text" asp-for="Floor" placeholder="Enter Floor" class="form-control" />
        <span asp-validation-for="Floor" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Description">Description</label>
        <input type="text" asp-for="Description" placeholder="Enter Description" class="form-control" />
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>
    <br>
    <div class="form-group">
        <input type="hidden" asp-for="LocationId" />
        <input type="submit" value="Submit" class="btn btn-success" />
    </div>
    
</form>


@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
